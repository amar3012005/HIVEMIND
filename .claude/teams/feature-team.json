      "agentType": "general-purpose",
      "model": "claude-sonnet-4-6"
    },
    {
      "name": "explorer",
      "agentType": "Explore",
      "model": "claude-haiku-4-5"
    },
    {
      "name": "tester",
      "agentType": "general-purpose",
      "model": "claude-sonnet-4-6"
    }
  ],
  "workflow": {
    "1_explore": "explorer searches codebase for related code and patterns",
    "2_plan": "feature-lead creates implementation plan",
