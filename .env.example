# HIVE-MIND - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env with real values to git
#
# 🔴 SECURITY NOTICE (2026-03-12): Previous Groq API key was compromised
#    Key pattern [REDACTED_COMPROMISED_KEY]
#    was found in git history and MUST be considered compromised.
#    - Generate a NEW key at https://console.groq.com/
#    - Revoke the old key immediately
#    - See: project_status/KEY_ROTATION_RECORD.md for full details

# ==========================================
# Core Application Settings
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# Groq API (for situationalization)
# Get key from: https://console.groq.com/
# ==========================================
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_INFERENCE_MODEL=llama-3.3-70b-versatile

# ==========================================
# Mistral AI API (for embeddings)
# Get key from: https://console.mistral.ai/
# ==========================================
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_EMBEDDING_MODEL=mistral-embed

# ==========================================
# Alternative: OpenAI API (for embeddings)
# ==========================================
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ==========================================
# PostgreSQL Database
# ==========================================
DATABASE_URL=postgres://hivemind:YOUR_PASSWORD_HERE@localhost:5432/hivemind

# ==========================================
# Qdrant Vector Database
# ==========================================
QDRANT_URL=http://localhost:9200
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=hivemind_memories

# ==========================================
# Redis (for sessions and cache)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password-here

# ==========================================
# Security (Generate your own keys)
# Generate with: openssl rand -hex 32
# ==========================================
API_MASTER_KEY=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32
HIVEMIND_MASTER_API_KEY=generate-with-openssl-rand-hex-32
HIVEMIND_ADMIN_SECRET=generate-with-openssl-rand-hex-32

# ==========================================
# EU Sovereign Settings (GDPR Compliance)
# ==========================================
EU_REGION=eu-central-1
DATA_RESIDENCY=EU
GDPR_MODE=true

# ==========================================
# Audit Logging
# ==========================================
AUDIT_LOG_PATH=./logs/audit.log
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_RETENTION_DAYS=2555

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Feature Flags
# ==========================================
USE_SITUATIONALIZER=true
USE_CONTEXTUAL_EMBEDDING=true
USE_AST_CHUNKING=true
USE_STATEFUL_MANAGER=true
USE_QDRANT_STORAGE=true

# ==========================================
# Sentry Error Tracking (Optional)
# Get DSN from: https://sentry.io/
# ==========================================
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=development

# ==========================================
# Backup Configuration (Optional)
# ==========================================
# BACKUP_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# BACKUP_S3_BUCKET=hivemind-backups
# BACKUP_S3_ACCESS_KEY=your-access-key
# BACKUP_S3_SECRET_KEY=your-secret-key
# BACKUP_ENCRYPTION_KEY=your-encryption-key
