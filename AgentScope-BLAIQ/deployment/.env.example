APP_ENV=production
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8090
HOST_PORT=8090

POSTGRES_DB=agentscope_blaiq
POSTGRES_USER=agentscope_blaiq
POSTGRES_PASSWORD=change-me
APP_DATABASE_URL=postgresql+asyncpg://agentscope_blaiq:change-me@postgres:5432/agentscope_blaiq

APP_REDIS_URL=redis://redis:6379/0

DEFAULT_TENANT=default
DEFAULT_SOURCE_SCOPE=web_and_docs
DEFAULT_ARTIFACT_TYPE=visual_html

LITELLM_PLANNER_MODEL=gemini-2.5-pro
LITELLM_PRE_MODEL=gemini-2.5-pro
LITELLM_POST_MODEL=gemini-2.5-pro
LITELLM_REFORMAT_MODEL=gemini-2.5-pro
LITELLM_TIMEOUT_SECONDS=25
LITELLM_MAX_OUTPUT_TOKENS=1200
LITELLM_API_BASE_URL=
LITELLM_API_KEY=
MODEL_REASONING_EFFORT=

STRATEGIC_MODEL=gemini-2.5-pro
RESEARCH_MODEL=gemini-2.5-pro
VANGOGH_MODEL=vertex_ai/claude-sonnet-4-6@default
GOVERNANCE_MODEL=gemini-2.5-pro
OPENAI_FALLBACK_MODEL=

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
ENABLE_GRAPH_AGENT=false
