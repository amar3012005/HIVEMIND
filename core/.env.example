# ==========================================
# HIVE-MIND Environment Configuration
# PostgreSQL + Apache AGE + Qdrant Stack
# EU Sovereign: GDPR, NIS2, DORA Compliant
# Data Residency: DE/FR/FI regions only
# ==========================================

# Copy this file to .env and fill in your values
# Never commit .env to version control

# ==========================================
# CORE DATABASE (PostgreSQL 15 + Apache AGE)
# ==========================================

# PostgreSQL connection for development (Docker)
POSTGRES_USER=hivemind
POSTGRES_PASSWORD=hivemind_dev_password_CHANGE_ME
POSTGRES_DB=hivemind

# Full connection string for Prisma
# Development (Docker internal network)
DATABASE_URL=postgres://hivemind:hivemind_dev_password_CHANGE_ME@localhost:5432/hivemind?schema=public

# Production (with SSL)
# DATABASE_URL=postgres://hivemind:PASSWORD@postgres:5432/hivemind?sslmode=require&sslcert=/etc/ssl/certs/client.crt&sslkey=/etc/ssl/private/client.key

# LUKS2 Encryption (HYOK - Hold Your Own Key)
# In production: Reference to OVHcloud HSM key
LUKS_KEY_ID=your-hsm-key-id-here
LUKS_PASSPHRASE=your-luks-passphrase-here

# HSM Master Key for encryption functions
# Production: Fetch from OVHcloud HSM via KMIP
HSM_MASTER_KEY=dev_hsm_master_key_CHANGE_IN_PRODUCTION

# ==========================================
# VECTOR DATABASE (Qdrant)
# ==========================================

# Qdrant connection for vector embeddings
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=dev_api_key_CHANGE_IN_PRODUCTION

# Qdrant gRPC endpoint (for high-performance vector search)
QDRANT_GRPC_URL=http://localhost:6334

# Collection configuration
QDRANT_COLLECTION_NAME=hivemind_memories
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE_METRIC=Cosine

# ==========================================
# IAM & IDENTITY (ZITADEL OIDC)
# ==========================================

# ZITADEL instance URL
ZITADEL_URL=http://localhost:8080
ZITADEL_ISSUER=http://localhost:8080

# ZITADEL database credentials (for self-hosted)
ZITADEL_DB_PASSWORD=zitadel_dev_password_CHANGE_ME
ZITADEL_MASTERKEY=MasterKeyForDevOnly123_CHANGE_IN_PRODUCTION

# OIDC Client Configuration
# Create in ZITADEL Console: Applications > New Application > Web
ZITADEL_CLIENT_ID=your-zitadel-client-id
ZITADEL_CLIENT_SECRET=your-zitadel-client-secret

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_AUDIENCE=hivemind-api
JWT_ISSUER=http://localhost:8080

# JWKS URI for token validation
JWKS_URI=http://localhost:8080/.well-known/jwks.json

# ==========================================
# MCP SERVER CONFIGURATION
# ==========================================

MCP_PORT=3000
MCP_TRANSPORT=sse
MCP_AUTH_SECRET=dev_secret_CHANGE_IN_PRODUCTION_64_CHARS_MINIMUM

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# AI MODELS (European Sovereign)
# ==========================================

# Groq Cloud API (Primary - Ultra-low latency, EU-compliant)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_EMBEDDING_MODEL=nomic-embed-text
GROQ_INFERENCE_MODEL=llama-3-3-70b-versatile

# Mistral AI (Alternative - EU-based, GDPR compliant)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_COMPLETION_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Aleph Alpha (Alternative - German AI, highest EU sovereignty)
ALEPH_ALPHA_API_KEY=your_aleph_alpha_key
ALEPH_ALPHA_MODEL=luminous-supreme
ALEPH_ALPHA_BASE_URL=https://api.aleph-alpha.com

# Local Embeddings (Ollama - for development/offline fallback)
EMBEDDING_MODEL_URL=http://localhost:11434
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_DIMENSION=768

# ==========================================
# REDIS (Session State & Pub/Sub)
# ==========================================

REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=false
# Production: REDIS_URL=rediss://default:PASSWORD@redis:6379

# ==========================================
# INFRASTRUCTURE PROVIDERS
# ==========================================

# Hetzner (Germany) - Primary compute
HCLOUD_TOKEN=your_hetzner_token
HCLOUD_DATACENTER=nbg1
HCLOUD_LOCATION=Nuremberg
HCLOUD_IMAGE=ubuntu-22.04

# Scaleway (France) - Managed PostgreSQL backup
SCW_ACCESS_KEY=your_scaleway_access_key
SCW_SECRET_KEY=your_scaleway_secret_key
SCW_DEFAULT_REGION=fr-par
SCW_DEFAULT_ZONE=fr-par-1
SCW_PROJECT_ID=your_scaleway_project_id

# OVHcloud (France) - Managed HSM for HYOK
OVH_APPLICATION_KEY=your_ovh_app_key
OVH_APPLICATION_SECRET=your_ovh_app_secret
OVH_CONSUMER_KEY=your_ovh_consumer_key
OVH_REGION=GRA
OVH_SERVICE_NAME=your_hsm_service_name

# ==========================================
# SECURITY & ENCRYPTION
# ==========================================

# OVHcloud Managed HSM (SecNumCloud qualified)
OVH_HSM_KEY_ID=your_hsm_key_id
HSM_TYPE=ovhcloud

# HYOK Configuration
HYOK_ENABLED=false
HYOK_KEY_SERVER=https://your-key-server.com
HYOK_KEY_ROTATION_DAYS=90

# Backup Encryption (GPG)
BACKUP_GPG_PASSPHRASE=generate_strong_gpg_passphrase
BACKUP_GPG_RECIPIENT=backup@hivemind.local

# SSL / TLS Configuration
ACME_EMAIL=admin@your-domain.com
TLS_MIN_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_AES_256_GCM_SHA384,TLS_CHACHA20_POLY1305_SHA256

# ==========================================
# MONITORING & OBSERVABILITY
# ==========================================

GRAFANA_URL=https://grafana.your-domain.com
GRAFANA_PASSWORD=generate_grafana_password

PROMETHESC_URL=http://localhost:9090
JAEGER_URL=http://localhost:16686

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SENSITIVE_DATA=false

# ==========================================
# BACKUP STORAGE (Scaleway S3 - EU)
# ==========================================

BACKUP_BUCKET=your-backup-bucket-name
BACKUP_REGION=fr-par
BACKUP_ENDPOINT=s3.fr-par.scw.cloud
BACKUP_ACCESS_KEY_ID=your_scaleway_access_key
BACKUP_SECRET_ACCESS_KEY=your_scaleway_secret_key

# Backup schedule (cron format)
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ==========================================
# COMPLIANCE SETTINGS
# ==========================================

# Data Residency (GDPR Article 44-50)
DATA_RESIDENCY=EU
ALLOWED_REGIONS=DE,FR,FI
DATA_TRANSFER_RESTRICTIONS=true

# GDPR Configuration
GDPR_MODE=strict
DATA_RETENTION_DAYS=2555
RIGHT_TO_ERASURE_ENABLED=true
DATA_PORTABILITY_ENABLED=true
CONSENT_MANAGEMENT_ENABLED=true

# NIS2 / DORA Compliance
NIS2_COMPLIANCE=enabled
DORA_COMPLIANCE=enabled
AUDIT_RETENTION_YEARS=7
INCIDENT_REPORTING_ENABLED=true
INCIDENT_REPORTING_EMAIL=security@hivemind.local

# ==========================================
# FEATURE FLAGS
# ==========================================

ENABLE_MCP_SERVER=true
ENABLE_AUTO_RECALL=true
ENABLE_SMART_FORGETTING=true
ENABLE_PREEMPTIVE_COMPACTION=true
ENABLE_HYOK=false
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true

# ==========================================
# PERFORMANCE TUNING
# ==========================================

# Context window management
MAX_CONTEXT_TOKENS=128000
COMPACTION_THRESHOLD=0.8
EMBEDDING_BATCH_SIZE=100

# Database connection pool
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=5000
DATABASE_IDLE_TIMEOUT=60000

# Query timeouts
QUERY_TIMEOUT_MS=3000
VECTOR_SEARCH_TIMEOUT_MS=500

# Memory management
MAX_MEMORY_USAGE_MB=512
GARBAGE_COLLECTION_INTERVAL_MS=300000

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

DEBUG=false
DEBUG_NAMESPACES=hivemind:*
NODE_ENV=development
ENABLE_DEV_TOOLS=true

# pgAdmin credentials (development only)
PGADMIN_EMAIL=admin@hivemind.local
PGADMIN_PASSWORD=admin

# Seed data for development
ENABLE_SEED_DATA=true
SEED_ORGANIZATION_NAME=HIVE-MIND Development
SEED_ADMIN_EMAIL=admin@hivemind.local
SEED_ADMIN_PASSWORD=DevPassword123!

# ==========================================
# CORS CONFIGURATION
# ==========================================

CORS_ENABLED=true
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID
CORS_EXPOSED_HEADERS=X-Request-ID,X-RateLimit-Limit,X-RateLimit-Remaining
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ==========================================
# API CONFIGURATION
# ==========================================

API_BASE_URL=/api/v1
API_VERSION=1.0.0
API_REQUEST_ID_HEADER=X-Request-ID
API_INCLUDE_STACK_TRACE=false

# ==========================================
# API KEY AUTHENTICATION
# ==========================================

# API Key Settings
API_KEY_ENABLED=true
API_KEY_HEADER=X-API-Key
API_KEY_QUERY_PARAM=api_key
API_KEY_PREFIX=hmk_

# Rate Limiting for API Keys
API_KEY_DEFAULT_RATE_LIMIT=60
API_KEY_MAX_RATE_LIMIT=1000

# API Key Expiry (default: never expires)
# Set to number of days (e.g., 90 = 90 days)
API_KEY_DEFAULT_EXPIRY_DAYS=

# Auto-revoke expired keys (days after expiry)
API_KEY_AUTO_REVOKE_EXPIRED_DAYS=30

# ==========================================
# HEALTH CHECKS
# ==========================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL_MS=30000
READINESS_CHECK_PATH=/ready
LIVENESS_CHECK_PATH=/live

# ==========================================
# METRICS
# ==========================================

METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_PORT=9090
