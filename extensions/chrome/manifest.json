{
  "manifest_version": 3,
  "name": "HIVEMIND — AI Memory Engine",
  "version": "1.0.0",
  "description": "Give your AI a perfect memory. Save web pages, auto-inject context into ChatGPT & Claude, and recall anything instantly.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://core.hivemind.davinciai.eu:8050/*",
    "https://api.hivemind.davinciai.eu:8040/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://claude.ai/*"],
      "js": ["content-ai-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
