{
  "manifest_version": 3,
  "name": "HIVEMIND — AI Memory Engine",
  "version": "1.1.0",
  "description": "Give your AI a perfect memory. Save web pages, auto-extract AI conversations, and recall anything instantly.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://core.hivemind.davinciai.eu:8050/*",
    "https://api.hivemind.davinciai.eu:8040/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["extractors.js", "content-ai-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["extractors.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
