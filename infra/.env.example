# HIVE-MIND Environment Configuration
# Copy this file to .env and fill in your values
# All data stays in EU jurisdiction (DE/FR/FI)

# ==========================================
# CORE DATABASE (PostgreSQL + Apache AGE)
# ==========================================
POSTGRES_USER=hivemind
POSTGRES_PASSWORD=generate_strong_password_here
POSTGRES_DB=hivemind
POSTGRES_URL=postgres://hivemind:${POSTGRES_PASSWORD}@postgres:5432/hivemind

# LUKS2 Encryption (HYOK - Hold Your Own Key)
LUKS_KEY_ID=your-hsm-key-id-here
LUKS_PASSPHRASE=your-luks-passphrase-here

# ==========================================
# VECTOR DATABASE (Qdrant)
# ==========================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=generate_qdrant_api_key

# ==========================================
# IAM & IDENTITY (ZITADEL)
# ==========================================
ZITADEL_DOMAIN=auth.your-domain.com
ZITADEL_DB_PASSWORD=generate_zitadel_db_password
ZITADEL_MASTERKEY=generate_32_char_masterkey
ZITADEL_URL=http://zitadel:8080

# ==========================================
# MCP SERVER
# ==========================================
MCP_PORT=3000
MCP_AUTH_SECRET=generate_64_char_secret
MCP_TRANSPORT=sse

# ==========================================
# AI MODELS (European Sovereign)
# ==========================================

# Mistral AI (Primary - EU-based)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_COMPLETION_MODEL=mistral-large-latest

# Aleph Alpha (Alternative - German)
ALEPH_ALPHA_API_KEY=your_aleph_alpha_key
ALEPH_ALPHA_MODEL=luminous-supreme

# Local Embeddings (Ollama)
EMBEDDING_MODEL_URL=http://embeddings:11434

# ==========================================
# INFRASTRUCTURE PROVIDERS
# ==========================================

# Hetzner (Germany)
HCLOUD_TOKEN=your_hetzner_token
HCLOUD_DATACENTER=nbg1  # Nuremberg or fsn1 (Falkenstein)

# Scaleway (France)
SCW_ACCESS_KEY=your_scaleway_access_key
SCW_SECRET_KEY=your_scaleway_secret_key
SCW_DEFAULT_REGION=fr-par
SCW_DEFAULT_ZONE=fr-par-1

# OVHcloud (France)
OVH_APPLICATION_KEY=your_ovh_app_key
OVH_APPLICATION_SECRET=your_ovh_app_secret
OVH_CONSUMER_KEY=your_ovh_consumer_key
OVH_REGION=GRA  # Gravelines

# ==========================================
# SECURITY & ENCRYPTION
# ==========================================

# OVHcloud Managed HSM
OVH_HSM_KEY_ID=your_hsm_key_id
HSM_TYPE=ovhcloud  # or thales, utimaco

# HYOK Configuration
HYOK_ENABLED=true
HYOK_KEY_SERVER=https://your-key-server.com
HYOK_KEY_ROTATION_DAYS=90

# Backup Encryption
BACKUP_GPG_PASSPHRASE=generate_strong_gpg_passphrase

# ==========================================
# SSL / TLS
# ==========================================
ACME_EMAIL=admin@your-domain.com

# ==========================================
# MONITORING
# ==========================================
GRAFANA_URL=https://grafana.your-domain.com
GRAFANA_PASSWORD=generate_grafana_password

# ==========================================
# BACKUP STORAGE (Scaleway S3 - EU)
# ==========================================
BACKUP_BUCKET=your-backup-bucket-name
BACKUP_REGION=fr-par

# ==========================================
# COMPLIANCE SETTINGS
# ==========================================

# Data Residency
DATA_RESIDENCY=EU  # Strict EU-only
ALLOWED_REGIONS=DE,FR,FI

# GDPR
GDPR_MODE=strict
DATA_RETENTION_DAYS=2555  # 7 years for NIS2/DORA
RIGHT_TO_ERASURE_ENABLED=true
DATA_PORTABILITY_ENABLED=true

# NIS2 / DORA
NIS2_COMPLIANCE=enabled
DORA_COMPLIANCE=enabled
AUDIT_RETENTION_YEARS=7
INCIDENT_REPORTING_ENABLED=true

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_MCP_SERVER=true
ENABLE_AUTO_RECALL=true
ENABLE_SMART_FORGETTING=true
ENABLE_PREEMPTIVE_COMPACTION=true
ENABLE_HYOK=false  # Set to true for enterprise

# ==========================================
# PERFORMANCE TUNING
# ==========================================
MAX_CONTEXT_TOKENS=128000
COMPACTION_THRESHOLD=0.8
EMBEDDING_BATCH_SIZE=100
QUERY_TIMEOUT_MS=300

# ==========================================
# DEVELOPMENT
# ==========================================
DEBUG=false
LOG_LEVEL=info
NODE_ENV=production
