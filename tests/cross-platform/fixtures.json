  "expectedBehaviors": {
    "crossPlatformRecall": {
      "description": "Memories from any platform should be recallable from any other platform",
      "test": "Create memory on platform A, recall from platform B",
      "expected": "Memory found with correct sourcePlatform field"
    },
    "contextInjection": {
      "description": "Context should be injected before LLM inference",
      "format": "XML with <relevant-memories> root element",
      "maxTokens": 2000,
      "maxMemories": 20
    },
    "memoryUpdates": {
      "description": "Updated memories should propagate to all platforms",
      "test": "Update memory created on platform A, verify visible from platform B",
      "expected": "Updated content visible within 1 second"
    },
    "scoringWeights": {
      "description": "Scoring should respect configured weights",
      "defaultWeights": {
        "similarity": 0.5,
        "recency": 0.3,
        "importance": 0.2
      },
      "test": "Query with low recency bias should favor high-importance memories"
    },
    "performance": {
      "description": "Recall latency should meet SLA",
      "p99Target": 300,
      "p95Target": 200,
      "p50Target": 100,
      "unit": "milliseconds"
    }
  },
  "validationRules": {
    "memoryContent": {
      "minLength": 1,
      "maxLength": 10000
    },
    "memoryTitle": {
      "maxLength": 500
    },
    "memoryTags": {
      "maxItems": 20,
      "tagMaxLength": 50
    },
    "importanceScore": {
      "min": 0,
      "max": 1
    },
    "recallLimit": {
      "min": 1,
      "max": 50,
      "default": 10
    }
  }
